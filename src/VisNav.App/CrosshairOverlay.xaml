<Window x:Class="VisNav.App.CrosshairOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        Focusable="False"
        SizeToContent="Manual"
        Title="VisNav Crosshair">
    <!-- A small window that follows the cursor. Under Per-Monitor-V2 the window adopts the
         scale of whatever monitor it's on, so the ring is correctly sized + centered on every
         monitor regardless of each one's display scaling. -->
    <Grid IsHitTestVisible="False">
        <Ellipse x:Name="OutlineRing" Fill="Transparent" Visibility="Collapsed"
                 HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
        <Ellipse x:Name="Ring" Fill="Transparent"
                 HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
    </Grid>
</Window>
