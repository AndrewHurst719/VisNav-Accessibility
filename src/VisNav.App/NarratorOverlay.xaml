<Window x:Class="VisNav.App.NarratorOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#14000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Hand"
        Title="VisNav Narrator"
        MouseMove="OnMouseMove"
        MouseLeftButtonDown="OnClick"
        MouseRightButtonDown="OnDismiss"
        KeyDown="OnKeyDown">
    <Canvas x:Name="RootCanvas" />
</Window>
