<Window x:Class="VisNav.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VisNav.App"
        mc:Ignorable="d"
        Title="VisNav Accessibility — Settings"
        Width="660" Height="860"
        MinWidth="520" MinHeight="560"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Ideal">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="VisNav Accessibility" FontSize="32" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" />
            <TextBlock Style="{StaticResource CaptionText}"
                       Text="Togglable visual and text to speech tools. Settings are saved automatically." />
        </StackPanel>

        <!-- Feature sections. Scrollbar hidden per request; wheel still scrolls and the window
             is resizable. -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Padding="0,0,4,0">
            <StackPanel>

                <!-- Crosshair -->
                <Border Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource HeadingText}" Text="Crosshair cursor" />
                        <TextBlock Style="{StaticResource CaptionText}"
                                   Text="A thin circle centered on your mouse pointer." Margin="0,0,0,4" />
                        <CheckBox Content="Enable crosshair" IsChecked="{Binding Crosshair.Enabled}"
                                  Checked="OnCrosshairChanged" Unchecked="OnCrosshairChanged" />

                        <TextBlock Text="Color" Margin="0,14,0,6" />
                        <WrapPanel x:Name="ColorSwatchPanel" />

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Outer circle radius" VerticalAlignment="Center" />
                            <Slider Grid.Row="0" Grid.Column="1" Minimum="10" Maximum="400" TickFrequency="10"
                                    AutoToolTipPlacement="TopLeft"
                                    Value="{Binding Crosshair.OuterRadius}"
                                    ValueChanged="OnCrosshairValueChanged" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Outer circle thickness" VerticalAlignment="Center" Margin="0,12,0,0" />
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="12" TickFrequency="1"
                                    Margin="0,12,0,0" AutoToolTipPlacement="TopLeft"
                                    Value="{Binding Crosshair.OuterThickness}"
                                    ValueChanged="OnCrosshairValueChanged" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Opacity (%)" VerticalAlignment="Center" Margin="0,12,0,0" />
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="10" Maximum="100" TickFrequency="5"
                                    Margin="0,12,0,0" AutoToolTipPlacement="TopLeft"
                                    Value="{Binding Crosshair.OpacityPercent}"
                                    ValueChanged="OnCrosshairValueChanged" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Magnifier -->
                <Border Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource HeadingText}" Text="Magnifier" />
                        <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,4"
                                   Text="Zooming tool based on your cursor position." />
                        <CheckBox Content="Enable magnifier" IsChecked="{Binding Magnifier.Enabled}"
                                  Checked="OnMagnifierChanged" Unchecked="OnMagnifierChanged" />

                        <!-- Activation hotkey -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Activation hotkey" VerticalAlignment="Center" />
                            <Border Grid.Column="1" x:Name="HotkeyBox" CornerRadius="4" Padding="12,8"
                                    Background="#101010" BorderThickness="2" BorderBrush="#3A3A3A">
                                <TextBlock x:Name="HotkeyText" FontSize="18" Text="(none)" />
                            </Border>
                            <Button Grid.Column="2" Content="Change…" MinWidth="0" Padding="14,8"
                                    Margin="8,0,0,0" Click="OnChangeHotkey" />
                        </Grid>
                        <TextBlock Style="{StaticResource CaptionText}" Margin="0,6,0,0"
                                   Text="Press the hotkey to toggle the lens. Shift + scroll wheel zooms while it's on." />

                        <!-- Starting zoom -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Starting zoom" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="1" Maximum="16" TickFrequency="0.5"
                                    AutoToolTipPlacement="TopLeft"
                                    Value="{Binding Magnifier.ZoomFactor}"
                                    ValueChanged="OnMagnifierValueChanged" />
                        </Grid>
                        <TextBlock Style="{StaticResource CaptionText}" Margin="0,6,0,0"
                                   Text="While the magnifier is on, hold Shift and scroll the mouse wheel up to zoom in, down to zoom out." />

                        <!-- Size diagram -->
                        <TextBlock Text="Lens size — drag the corner handle" Margin="0,16,0,6" />
                        <Border Background="#0C0C0C" CornerRadius="6" Padding="12"
                                HorizontalAlignment="Left">
                            <Canvas x:Name="SizeDiagram" Width="300" Height="200" Background="#0C0C0C">
                                <Rectangle x:Name="LensRect" Canvas.Left="0" Canvas.Top="0"
                                           Stroke="{StaticResource AccentBrush}" StrokeThickness="2"
                                           Fill="#3300E5FF" />
                                <Thumb x:Name="CornerThumb" Width="22" Height="22"
                                       Cursor="SizeNWSE" DragDelta="OnCornerDrag">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{StaticResource AccentBrush}"
                                                    BorderBrush="#121212" BorderThickness="2" CornerRadius="3" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Canvas>
                        </Border>
                        <TextBlock x:Name="LensSizeText" Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Narrator -->
                <Border Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="18" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource HeadingText}" Text="Narrator" />
                        <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,4"
                                   Text="Scan the page and hover over text to find highlighted text-to-speech bubbles. Scan whatever needs reading." />
                        <CheckBox Content="Enable narrator" IsChecked="{Binding Narrator.Enabled}"
                                  Checked="OnNarratorChanged" Unchecked="OnNarratorChanged" />

                        <!-- Scan hotkey -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Scan hotkey" VerticalAlignment="Center" />
                            <Border Grid.Column="1" x:Name="ScanHotkeyBox" CornerRadius="4" Padding="12,8"
                                    Background="#101010" BorderThickness="2" BorderBrush="#3A3A3A">
                                <TextBlock x:Name="ScanHotkeyText" FontSize="18" Text="(none)" />
                            </Border>
                            <Button Grid.Column="2" Content="Change…" MinWidth="0" Padding="14,8"
                                    Margin="8,0,0,0" Click="OnChangeScanHotkey" />
                        </Grid>

                        <!-- Read-a-region hotkey (OCR) -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Read-region hotkey" VerticalAlignment="Center" />
                            <Border Grid.Column="1" x:Name="RegionHotkeyBox" CornerRadius="4" Padding="12,8"
                                    Background="#101010" BorderThickness="2" BorderBrush="#3A3A3A">
                                <TextBlock x:Name="RegionHotkeyText" FontSize="18" Text="(none)" />
                            </Border>
                            <Button Grid.Column="2" Content="Change…" MinWidth="0" Padding="14,8"
                                    Margin="8,0,0,0" Click="OnChangeRegionHotkey" />
                        </Grid>
                        <TextBlock Style="{StaticResource CaptionText}" Margin="0,6,0,0"
                                   Text="Crop out what needs read — Esc to dismiss." />

                        <!-- Pause/resume hotkey -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pause / resume hotkey" VerticalAlignment="Center" />
                            <Border Grid.Column="1" x:Name="PauseHotkeyBox" CornerRadius="4" Padding="12,8"
                                    Background="#101010" BorderThickness="2" BorderBrush="#3A3A3A">
                                <TextBlock x:Name="PauseHotkeyText" FontSize="18" Text="(none)" />
                            </Border>
                            <Button Grid.Column="2" Content="Change…" MinWidth="0" Padding="14,8"
                                    Margin="8,0,0,0" Click="OnChangePauseHotkey" />
                        </Grid>

                        <!-- Stop hotkey -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Stop hotkey" VerticalAlignment="Center" />
                            <Border Grid.Column="1" x:Name="StopHotkeyBox" CornerRadius="4" Padding="12,8"
                                    Background="#101010" BorderThickness="2" BorderBrush="#3A3A3A">
                                <TextBlock x:Name="StopHotkeyText" FontSize="18" Text="(none)" />
                            </Border>
                            <Button Grid.Column="2" Content="Change…" MinWidth="0" Padding="14,8"
                                    Margin="8,0,0,0" Click="OnChangeStopHotkey" />
                        </Grid>
                        <TextBlock Style="{StaticResource CaptionText}" Margin="0,6,0,0"
                                   Text="Pause/resume and stop work for any speech (block reading or region reading)." />

                        <!-- Voice -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Voice" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1" x:Name="VoiceCombo" FontSize="18" Height="36"
                                      Foreground="Black" Background="White"
                                      SelectionChanged="OnVoiceChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="Black" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <!-- Rate -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Speech rate" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="-10" Maximum="10" TickFrequency="1"
                                    AutoToolTipPlacement="TopLeft"
                                    Value="{Binding Narrator.SpeechRate}"
                                    ValueChanged="OnNarratorValueChanged" />
                        </Grid>

                        <!-- Grouping intensity -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Grouping intensity" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="1" Maximum="10" TickFrequency="1"
                                    IsSnapToTickEnabled="True" AutoToolTipPlacement="TopLeft"
                                    Value="{Binding Narrator.GroupingIntensity}"
                                    ValueChanged="OnNarratorValueChanged" />
                        </Grid>
                        <TextBlock Style="{StaticResource CaptionText}" Margin="0,6,0,0"
                                   Text="Higher = smaller, tighter groups. Lower = bigger groups spanning multiple paragraphs." />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Style="{StaticResource CaptionText}" VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Text="Crosshair, Magnifier, and Narrator are all live. Settings save automatically." />
            <Button Grid.Column="1" Content="Close" VerticalAlignment="Center" MinWidth="120" Click="OnCloseClick" />
        </Grid>
    </Grid>
</Window>
